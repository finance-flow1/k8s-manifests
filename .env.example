# =============================================================================
# .env.example — Sealed Secrets credential template
#
# INSTRUCTIONS:
#   1. Copy this file to .env:  cp .env.example .env
#   2. Replace every <placeholder> with your real value
#   3. The .env file is git-ignored and MUST NEVER be committed
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=finance_admin
USER_DB_NAME=user_db
TXN_DB_NAME=txn_db
NOTIFY_DB_NAME=notify_db

# Development DB password
DEV_POSTGRES_PASSWORD=<your-dev-db-password>

# Production DB password (use a strong, unique password)
PROD_POSTGRES_PASSWORD=<your-prod-db-password>

# --- JWT ---
# Development signing secret (can be simple for dev)
DEV_JWT_SECRET=<your-dev-jwt-secret>

# Production signing secret (must be long, random, and unique)
PROD_JWT_SECRET=<your-prod-jwt-secret>

# --- RabbitMQ ---
RABBITMQ_USER=<your-rabbitmq-user>
RABBITMQ_PASSWORD=<your-rabbitmq-password>
